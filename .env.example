# Kafka Configurations
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_TRAFFIC=traffic-stream
KAFKA_TOPIC_WEATHER=weather-stream
KAFKA_TOPIC_PREDICTION=prediction-stream
KAFKA_GROUP_ID=smartcity-group
KAFKA_AUTO_OFFSET_RESET=earliest

# PostgreSQL Configurations
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartcity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# HDFS Configurations
HDFS_NAMENODE=localhost
HDFS_PORT=9870
HDFS_USER=hadoop
HDFS_BASE_PATH=/smartcity

# Spark Configurations
SPARK_MASTER=local[*]
SPARK_APP_NAME=SmartCityPlatform
SPARK_STREAMING_INTERVAL=5

# Dashboard & API
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data
MODEL_DIR=./ml/models
CHECKPOINT_DIR=./spark/checkpoints
